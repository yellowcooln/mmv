{
  "name": "mmv",
  "version": "1.0.0",
  "description": "Mesh network visualizer - MQTT-connected MeshCore node topology viewer",
  "main": "dist/index.js",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "cd client && npm run build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/index.js",
    "clean": "rm -rf dist client/dist"
  },
  "dependencies": {
    "@michaelhart/meshcore-decoder": "^0.2.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mqtt": "^5.7.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.13",
    "@types/ws": "^8.5.12",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
