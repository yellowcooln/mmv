# MQTT broker settings
MQTT_URL=mqtt://mqtt.eastmesh.au:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=mmv-visualizer
MQTT_RAW_TOPIC=meshcore/+/+/raw
# Stream suffix can be /raw or /packets depending on your broker publisher
# Optional comma-separated observer public keys/prefixes to pre-populate nodes on connect
# MQTT_OBSERVERS=0xA1B2C3...,7E76...
# Optional display label shown in the UI header/empty-state
# (defaults to MQTT_URL hostname)
# MQTT_DISPLAY_NAME=

# Server settings
PORT=3001

# SQLite database path
DB_PATH=./data/mmv.db
