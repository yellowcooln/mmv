# MQTT broker settings
MQTT_URL=mqtt://mqtt.example.com:1883
# Optional display name for the MQTT broker shown in the UI (defaults to hostname from MQTT_URL)
# MQTT_DISPLAY_NAME=My Broker
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=mmv-visualizer
MQTT_TOPIC=meshcore/+/+/packets
# Optional comma-separated observer public keys/prefixes to pre-populate nodes on connect
# MQTT_OBSERVERS=0xA1B2C3...,7E76...

# Server settings
PORT=3001
# Minimum number of packets seen on a path before an edge is shown in the graph (default: 5)
# MIN_EDGE_PACKETS=5
# Packet deduplication — when enabled, packets with a message hash already seen recently are
# skipped so the same broadcast retransmission is not counted multiple times.
# Set to true to enable; false (default) counts every copy.
# DEDUPE_ENABLED=false

# Vite dev server port (default: 9001)
# VITE_PORT=9001

# Geographic layout influence — set to false to disable geo-seeded node positions
# and the Geo influence slider entirely (default: true)
# GEO_ENABLED=false

# Optional fixed centre point for the geographic layout projection.
# When set, all node positions are projected relative to this lat/lng instead of
# the centroid of currently-known nodes. Useful for keeping the layout stable as
# new nodes are discovered at the edges of the mesh.
# CENTER_LAT=51.5
# CENTER_LON=-0.12

# SQLite database path
DB_PATH=./data/mmv.db
