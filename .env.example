# MQTT broker settings
MQTT_URL=mqtt://mqtt.example.com:1883
# Optional display name for the MQTT broker shown in the UI (defaults to hostname from MQTT_URL)
# MQTT_DISPLAY_NAME=My Broker
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=mmv-visualizer
MQTT_TOPIC=meshcore/+/+/packets
# Optional comma-separated observer public keys/prefixes to pre-populate nodes on connect
# MQTT_OBSERVERS=0xA1B2C3...,7E76...

# Server settings
PORT=3001
# Minimum number of packets seen on a path before an edge is shown in the graph (default: 5)
# MIN_EDGE_PACKETS=5

# Vite dev server port (default: 9001)
# VITE_PORT=9001

# SQLite database path
DB_PATH=./data/mmv.db
