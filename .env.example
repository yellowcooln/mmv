# MQTT Broker settings
MQTT_URL=mqtt://mqtt.eastmesh.au:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=mmv-visualizer
MQTT_RAW_TOPIC=meshcore/+/+/raw
MQTT_PACKETS_TOPIC=meshcore/+/+/packets
# /raw is decoded with meshcore-decoder; /packets is consumed as pre-decoded JSON

# Server settings
PORT=3001

# SQLite database path
DB_PATH=./data/mmv.db
